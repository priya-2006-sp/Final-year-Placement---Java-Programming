import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;
public class Solution {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n1=sc.nextInt();
        int sum=0;
        String space="";
        for(int i=1;i<=n1;i++){
            sum+=i;
            space+=sum+" ";
        }
        System.out.print("Number series from 1 to " +n1+ " is "+space);
    }
}
